# Backend API
# Dev infra runs in Docker (docker-compose.dev.yml): Postgres on 5435, Redis on 6380.
DATABASE_URL=postgresql://budlog:budlog@localhost:5435/budlog_dev
REDIS_URL=redis://localhost:6380
JWT_SECRET=your-jwt-secret-here
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of allowed origins.
# Leave unset for local dev (defaults to localhost:8081 and localhost:3001)
CORS_ORIGIN=

# Admin panel — comma-separated emails allowed into /admin/* (and apps/web /admin)
ADMIN_EMAILS=

# LangSmith — AI tracing/observability (optional). Set LANGSMITH_TRACING=true to enable.
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=budlog

# Telegram bot (create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=
# Secret token passed to Telegram setWebhook (required in production webhook mode)
TELEGRAM_WEBHOOK_SECRET=your-telegram-webhook-secret

# --- Phase 2+ (not used yet) ---
# OPENAI_API_KEY=

# --- Optional ---
# Firebase (push notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
# Email (SMTP) for verification / reset codes
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
# Sentry error tracking (no-op when unset)
SENTRY_DSN=
