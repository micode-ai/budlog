FROM node:20-alpine AS base
WORKDIR /app

# --- deps ---
FROM base AS deps
COPY package.json package-lock.json turbo.json ./
COPY apps/web/package.json ./apps/web/
# Stub the api workspace so npm resolves the lockfile without pulling the API tree.
RUN mkdir -p apps/api && echo '{"name":"@budlog/api","version":"0.1.0","private":true}' > apps/api/package.json
RUN npm install --legacy-peer-deps --no-audit --no-fund

# --- builder ---
FROM base AS builder
COPY --from=deps /app ./
COPY apps/web ./apps/web

# Baked into the client bundle — point at the public API origin.
ARG NEXT_PUBLIC_API_URL=
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL

WORKDIR /app/apps/web
RUN mkdir -p public
RUN npm run build

# --- runner (Next standalone) ---
FROM base AS runner
ENV NODE_ENV=production
ENV HOSTNAME=0.0.0.0
ENV PORT=3001

# Monorepo standalone output (outputFileTracingRoot = repo root).
COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/public ./apps/web/public

EXPOSE 3001

HEALTHCHECK --interval=30s --timeout=3s --start-period=10s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3001/', (r) => {process.exit(r.statusCode < 500 ? 0 : 1)}).on('error', () => process.exit(1))" || exit 1

CMD ["node", "apps/web/server.js"]
