# ──────────────────────────────────────
# Database
# ──────────────────────────────────────
DATABASE_URL=postgresql://budlog:budlog@127.0.0.1:5435/budlog_dev

# ──────────────────────────────────────
# Redis
# ──────────────────────────────────────
REDIS_URL=redis://localhost:6380

# ──────────────────────────────────────
# JWT Auth
# ──────────────────────────────────────
JWT_SECRET=changeme
JWT_REFRESH_SECRET=changeme
JWT_EXPIRES_IN=7d

# ──────────────────────────────────────
# OpenAI
# ──────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────
# Telegram bot — create via @BotFather; leave blank to disable.
# ──────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# ──────────────────────────────────────
# Server
# ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# Admin panel access — comma-separated emails allowed into /admin/*
ADMIN_EMAILS=

# ──────────────────────────────────────
# LangSmith (AI observability) — optional. Leave LANGSMITH_TRACING unset to disable.
# ──────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=budlog

# ──────────────────────────────────────
# File uploads — local disk store (replace with S3 path in prod)
# ──────────────────────────────────────
UPLOAD_DIR=uploads
