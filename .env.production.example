# BudLog production env — copy to .env.production on the VPS (NEVER commit the real file).
# Consumed by docker-compose.prod.yml (api service env_file + interpolation).

# ── Postgres (compose creates the DB with these) ──
POSTGRES_USER=budlog
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=budlog

# ── App secrets ──
JWT_SECRET=change-me-64-hex
JWT_REFRESH_SECRET=change-me-64-hex
JWT_EXPIRES_IN=7d

# Public origins allowed by CORS (NOT "*"). The web app + any tooling.
CORS_ORIGIN=https://budlog.pl,https://www.budlog.pl

# Base URL the bot puts in /report links → the public web app.
REPORT_BASE_URL=https://budlog.pl/r

# Admin panel access (comma-separated emails).
ADMIN_EMAILS=you@example.com

# ── Telegram ──
TELEGRAM_BOT_TOKEN=
# In production prefer webhook mode:
TELEGRAM_WEBHOOK_URL=https://api.budlog.pl
TELEGRAM_WEBHOOK_SECRET=change-me

# ── OpenAI (Phase 2 capture) ──
OPENAI_API_KEY=

# ── LangSmith (AI observability) — optional. Set LANGSMITH_TRACING=true to enable. ──
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=budlog

# ── Optional ──
SENTRY_DSN=
SMTP_HOST=
SMTP_USER=
SMTP_PASS=

# Used at web image build time (compose passes it as a build arg):
NEXT_PUBLIC_API_URL=https://api.budlog.pl
